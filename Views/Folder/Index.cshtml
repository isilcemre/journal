@model List<deneme2._0.Models.Folder>

@{
    ViewData["Title"] = "Klasörlerim";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@@0,400;0,600;1,400&family=DM+Sans:wght@@300;400;500&display=swap');

    :root {
        --ink: #2C2416;
        --ink-soft: #6B5E4A;
        --ink-faint: #A89880;
        --paper: #FAF7F2;
        --paper-warm: #F3EDE3;
        --paper-crease: #E8DFD0;
        --accent: #8B4513;
        --accent-light: #D4956A;
        --accent-glow: rgba(139, 69, 19, 0.12);
        --shadow-soft: 0 2px 16px rgba(44, 36, 22, 0.08);
        --shadow-lift: 0 6px 28px rgba(44, 36, 22, 0.14);
    }

    body {
        background: var(--paper);
        font-family: 'DM Sans', sans-serif;
        color: var(--ink);
    }

    .folders-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 16px 64px;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .page-title {
        font-family: 'Lora', serif;
        font-size: 28px;
        font-weight: 400;
        font-style: italic;
        color: var(--ink);
        margin: 0;
    }

    .btn-create {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        background: var(--accent);
        color: #FFF8F0;
        border: none;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.18s;
    }

        .btn-create:hover {
            background: #7A3B10;
            color: #FFF8F0;
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(139,69,19,0.3);
        }

    /* Bölüm başlıkları */
    .section-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-faint);
        margin: 28px 0 12px;
    }

    /* Klasör grid */
    .folder-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 14px;
    }

    .folder-card {
        background: #FFFDF8;
        border: 1px solid var(--paper-crease);
        border-radius: 16px;
        padding: 20px 18px 16px;
        text-decoration: none;
        color: var(--ink);
        transition: all 0.2s ease;
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: relative;
        box-shadow: var(--shadow-soft);
    }

        .folder-card:hover {
            box-shadow: var(--shadow-lift);
            transform: translateY(-2px);
            border-color: var(--accent-light);
            color: var(--ink);
            text-decoration: none;
        }

    .folder-emoji {
        font-size: 32px;
        line-height: 1;
    }

    .folder-name {
        font-family: 'Lora', serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

    .folder-count {
        font-size: 12px;
        color: var(--ink-faint);
    }

    .folder-default-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        font-size: 10px;
        font-weight: 600;
        color: var(--ink-faint);
        background: var(--paper-warm);
        border-radius: 6px;
        padding: 2px 7px;
        letter-spacing: 0.05em;
    }

    .folder-delete-btn {
        position: absolute;
        bottom: 10px;
        right: 10px;
        background: transparent;
        border: none;
        color: var(--ink-faint);
        font-size: 13px;
        cursor: pointer;
        padding: 4px 6px;
        border-radius: 6px;
        transition: all 0.15s;
        display: none;
    }

    .folder-card:hover .folder-delete-btn {
        display: block;
    }

    .folder-delete-btn:hover {
        background: rgba(180, 50, 50, 0.1);
        color: #c0392b;
    }

    /* Yeni klasör formu */
    .create-form-box {
        background: #FFFDF8;
        border: 1.5px dashed var(--paper-crease);
        border-radius: 16px;
        padding: 24px;
        margin-top: 32px;
        display: none;
    }

        .create-form-box.open {
            display: block;
        }

        .create-form-box h3 {
            font-family: 'Lora', serif;
            font-size: 17px;
            font-weight: 600;
            margin: 0 0 18px;
            color: var(--ink);
        }

    .form-row {
        display: flex;
        gap: 10px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }

    .form-input {
        flex: 1;
        min-width: 160px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1.5px solid var(--paper-crease);
        background: var(--paper);
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: var(--ink);
        outline: none;
        transition: border-color 0.2s;
    }

        .form-input:focus {
            border-color: var(--accent-light);
        }

    .emoji-input {
        width: 70px;
        flex: none;
        text-align: center;
        font-size: 20px;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 4px;
    }

    .btn-save {
        padding: 9px 20px;
        border-radius: 10px;
        background: var(--accent);
        color: #FFF8F0;
        border: none;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.18s;
    }

        .btn-save:hover {
            background: #7A3B10;
        }

    .btn-cancel {
        padding: 9px 16px;
        border-radius: 10px;
        background: transparent;
        color: var(--ink-soft);
        border: 1.5px solid var(--paper-crease);
        font-size: 13px;
        cursor: pointer;
        transition: background 0.15s;
    }

        .btn-cancel:hover {
            background: var(--paper-warm);
        }

    .alert-msg {
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 13px;
        margin-bottom: 20px;
    }

    .alert-success {
        background: rgba(92, 122, 78, 0.12);
        color: #3d6b31;
    }

    .alert-error {
        background: rgba(180, 50, 50, 0.1);
        color: #c0392b;
    }
</style>

<div class="folders-page">

    <div class="page-header">
        <h1 class="page-title">📁 Klasörlerim</h1>
        <button class="btn-create" onclick="toggleForm()">+ Yeni Klasör</button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-msg alert-success">✓ @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-msg alert-error">⚠ @TempData["ErrorMessage"]</div>
    }

    <!-- Varsayılan Klasörler -->
    @{
        var defaultFolders = Model.Where(f => f.IsDefault).ToList();
        var customFolders = Model.Where(f => !f.IsDefault).ToList();
    }

    @if (defaultFolders.Any())
    {
        <div class="section-label">Varsayılan Klasörler</div>
        <div class="folder-grid">
            @foreach (var folder in defaultFolders)
            {
                <a asp-action="Details" asp-route-id="@folder.Id" class="folder-card">
                    <span class="folder-default-badge">varsayılan</span>
                    <span class="folder-emoji">@folder.Emoji</span>
                    <p class="folder-name">@folder.Name</p>
                    <span class="folder-count">
                        @folder.JournalEntryFolders.Count günlük
                    </span>
                </a>
            }
        </div>
    }

    <!-- Kullanıcı Klasörleri -->
    @if (customFolders.Any())
    {
        <div class="section-label">Klasörlerim</div>
        <div class="folder-grid">
            @foreach (var folder in customFolders)
            {
                <a asp-action="Details" asp-route-id="@folder.Id" class="folder-card">
                    <span class="folder-emoji">@folder.Emoji</span>
                    <p class="folder-name">@folder.Name</p>
                    <span class="folder-count">
                        @folder.JournalEntryFolders.Count günlük
                    </span>
                    <form asp-action="Delete" asp-route-id="@folder.Id" method="post"
                          onclick="event.stopPropagation()">
                        <button type="submit" class="folder-delete-btn"
                                onclick="return confirm('Bu klasörü silmek istediğinizden emin misiniz?')">
                            🗑
                        </button>
                    </form>
                </a>
            }
        </div>
    }

    @if (!defaultFolders.Any() && !customFolders.Any())
    {
        <p style="color:var(--ink-faint); text-align:center; margin-top:48px;">
            Henüz klasörünüz yok. Yukarıdan yeni klasör oluşturun.
        </p>
    }

    <!-- Yeni Klasör Formu -->
    <div class="create-form-box" id="createForm">
        <h3>Yeni Klasör Oluştur</h3>
        <form asp-action="Create" method="post">
            <div class="form-row">
                <div style="position:relative;">
                    <button type="button" class="form-input emoji-input" id="emojiPickerBtn"
                            onclick="toggleEmojiPicker()"
                            style="cursor:pointer; font-size:20px; text-align:center; background:#FAF7F2;">
                        📁
                    </button>
                    <input type="hidden" name="emoji" id="emojiValue" value="📁" />

                    <!-- Emoji Picker -->
                    <div id="emojiPicker" style="display:none; position:absolute; top:48px; left:0;
                        background:#FFFDF8; border:1.5px solid #E8DFD0; border-radius:14px;
                        padding:12px; box-shadow:0 6px 28px rgba(44,36,22,0.14);
                        z-index:999; width:280px;">

                        @{
                            var emojiGroups = new Dictionary<string, string[]>
                {
                    { "📚 Genel", new[] { "📁", "📂", "🗂️", "📋", "📌", "📍", "🗒️", "📝", "✏️", "🖊️" } },
                    { "😊 Duygular", new[] { "❤️", "💛", "💚", "💙", "💜", "🖤", "🤍", "😊", "😢", "😤" } },
                    { "🌿 Doğa", new[] { "🌸", "🌺", "🌻", "🌹", "🍀", "🌿", "🍃", "🌲", "⭐", "🌙" } },
                    { "🏃 Aktivite", new[] { "💪", "🏃", "🧘", "🚴", "⚽", "🎯", "🏆", "🎮", "🎨", "🎵" } },
                    { "✈️ Seyahat", new[] { "✈️", "🚂", "🚢", "🏖️", "🏔️", "🗺️", "🧳", "🌍", "🏕️", "🗼" } },
                    { "🍕 Yemek", new[] { "🍕", "🍔", "🍣", "🍜", "☕", "🍰", "🍎", "🥗", "🍷", "🧁" } },
                    { "💼 İş", new[] { "💼", "💻", "📊", "📈", "🖥️", "⌨️", "📱", "🔑", "💡", "🏢" } },
                    { "🏠 Ev", new[] { "🏠", "🛋️", "🛏️", "🪴", "🐱", "🐶", "👨‍👩‍👧", "💒", "🎁", "🕯️" } },
                };
                        }

                        @foreach (var group in emojiGroups)
                        {
                            <div style="margin-bottom:10px;">
                                <div style="font-size:11px; font-weight:600; color:#A89880;
                                    text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px;">
                                    @group.Key
                                </div>
                                <div style="display:flex; flex-wrap:wrap; gap:4px;">
                                    @foreach (var emoji in group.Value)
                                    {
                                        <button type="button"
                                                onclick="selectEmoji('@emoji')"
                                                style="width:34px; height:34px; border:none; background:transparent;
                                            border-radius:8px; font-size:18px; cursor:pointer;
                                            transition:background 0.15s;"
                                                onmouseover="this.style.background='rgba(139,69,19,0.10)'"
                                                onmouseout="this.style.background='transparent'">
                                            @emoji
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <input type="text" name="name" placeholder="Klasör adı" class="form-input" required />
            </div>
            <input type="text" name="description" placeholder="Açıklama (isteğe bağlı)"
                   class="form-input" style="width:100%; margin-bottom:14px;" />
            <div class="form-actions">
                <button type="submit" class="btn-save">Oluştur</button>
                <button type="button" class="btn-cancel" onclick="toggleForm()">İptal</button>
            </div>
        </form>
    </div>

</div>

<script>
    function toggleForm() {
        document.getElementById('createForm').classList.toggle('open');
    }

    function toggleEmojiPicker() {
        const picker = document.getElementById('emojiPicker');
        picker.style.display = picker.style.display === 'none' ? 'block' : 'none';
    }

    function selectEmoji(emoji) {
        document.getElementById('emojiPickerBtn').textContent = emoji;
        document.getElementById('emojiValue').value = emoji;
        document.getElementById('emojiPicker').style.display = 'none';
    }

    // Dışarı tıklayınca kapat
    document.addEventListener('click', function(e) {
        const picker = document.getElementById('emojiPicker');
        const btn = document.getElementById('emojiPickerBtn');
        if (picker && !picker.contains(e.target) && e.target !== btn) {
            picker.style.display = 'none';
        }
    });

</script>