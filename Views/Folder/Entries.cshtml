@model deneme2._0.Models.Folder
@{
    ViewData["Title"] = Model.Name + " Klasörü";
}

<style>
    .entries-page {
        min-height: 80vh;
        background: #FAF7F2;
        padding: 2rem 1rem 4rem;
        font-family: 'DM Sans', sans-serif;
    }

    .entries-container {
        max-width: 760px;
        margin: 0 auto;
    }

    .entries-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 10px;
    }

    .entries-header-left .breadcrumb {
        font-size: 11.5px;
        font-weight: 500;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: #A89880;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .breadcrumb a {
        color: #A89880;
        text-decoration: none;
        transition: color .14s;
    }

        .breadcrumb a:hover {
            color: #8B4513;
        }

    .entries-header-left h2 {
        font-family: 'Lora', serif;
        font-size: 26px;
        font-weight: 400;
        font-style: italic;
        color: #2C2416;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .entries-header-left h2 .folder-icon {
            font-size: 24px;
            font-style: normal;
        }

    .entry-count-chip {
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-style: normal;
        font-weight: 500;
        color: #8B4513;
        background: rgba(139,69,19,0.09);
        border-radius: 20px;
        padding: 3px 11px;
        vertical-align: middle;
    }

    /* Entry list */
    .entries-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .entry-card {
        background: #FFFDF8;
        border: 1px solid #E8DFD0;
        border-radius: 16px;
        padding: 1.3rem 1.4rem;
        display: flex;
        gap: 16px;
        align-items: flex-start;
        box-shadow: 0 2px 10px rgba(44,36,22,0.05);
        transition: box-shadow .18s, transform .15s, border-color .15s;
        text-decoration: none;
    }

        .entry-card:hover {
            box-shadow: 0 6px 22px rgba(44,36,22,0.10);
            transform: translateY(-2px);
            border-color: #D4956A;
            text-decoration: none;
        }

    /* Küçük fotoğraf önizleme */
    .entry-thumb {
        width: 68px;
        height: 68px;
        border-radius: 10px;
        object-fit: cover;
        flex-shrink: 0;
        background: #F0EAE0;
    }

    .entry-thumb-placeholder {
        width: 68px;
        height: 68px;
        border-radius: 10px;
        background: #F0EAE0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .entry-body {
        flex: 1;
        min-width: 0;
    }

    .entry-meta {
        font-size: 11.5px;
        color: #A89880;
        letter-spacing: .04em;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .entry-title {
        font-family: 'Lora', serif;
        font-size: 16.5px;
        font-weight: 600;
        color: #2C2416;
        margin-bottom: 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .entry-excerpt {
        font-size: 13px;
        color: #6B5744;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Empty state */
    .entries-empty {
        text-align: center;
        padding: 3rem 1rem;
        color: #A89880;
    }

    .entries-empty-icon {
        font-size: 44px;
        margin-bottom: 12px;
    }

    .entries-empty p {
        font-size: 14px;
        margin: 0 0 16px;
    }

    .btn-new-entry {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        height: 40px;
        padding: 0 20px;
        background: #8B4513;
        color: #FFF8F0;
        border: none;
        border-radius: 10px;
        font-family: 'Lora', serif;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: background .18s, transform .15s;
    }

        .btn-new-entry:hover {
            background: #7A3B10;
            transform: translateY(-1px);
            color: #FFF8F0;
            text-decoration: none;
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 38px;
        padding: 0 16px;
        background: transparent;
        color: #6B5744;
        border: 1.5px solid #D4C5B0;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: background .15s;
    }

        .btn-back:hover {
            background: rgba(139,69,19,0.06);
            color: #2C2416;
            text-decoration: none;
        }
</style>

<div class="entries-page">
    <div class="entries-container">

        <div class="entries-header">
            <div class="entries-header-left">
                <div class="breadcrumb">
                    <a asp-controller="Folder" asp-action="Index">📁 Klasörler</a>
                    <span>›</span>
                    <span>@Model.Name</span>
                </div>
                <h2>
                    <span class="folder-icon">@Model.Emoji</span>
                    @Model.Name
                    <span class="entry-count-chip">@Model.Entries.Count günlük</span>
                </h2>
            </div>
            <div style="display:flex; gap:10px;">
                <a asp-controller="Folder" asp-action="Index" class="btn-back">
                    <i class="bi bi-chevron-left"></i> Geri
                </a>
            </div>
        </div>

        @if (!Model.Entries.Any())
        {
            <div class="entries-empty">
                <div class="entries-empty-icon">📝</div>
                <p>Bu klasörde henüz günlük yok.</p>
                <a asp-controller="Journal" asp-action="Create" class="btn-new-entry">
                    <i class="bi bi-plus-lg"></i> İlk günlüğü ekle
                </a>
            </div>
        }
        else
        {
            <div class="entries-list">
                @foreach (var entry in Model.Entries.OrderByDescending(e => e.CreatedAt))
                {
                    <a asp-controller="Journal" asp-action="Details" asp-route-id="@entry.Id"
                       class="entry-card">

                        @{
                            var firstImage = entry.Images?.FirstOrDefault();
                        }
                        @if (entry.Images != null && entry.Images.Any())
                        {
                            <img src="data:@entry.Images.First().ImageContentType;base64,@Convert.ToBase64String(entry.Images.First().ImageData)"
                                 class="entry-thumb" alt="" />
                        }
                        else
                        {
                            <div class="entry-thumb-placeholder">📝</div>
                        }

                    <div class="entry-body">
                        <div class="entry-meta">
                            <i class="bi bi-calendar3"></i>
                            @entry.CreatedAt.ToString("dd MMM yyyy")
                        </div>
                        <div class="entry-title">@entry.Title</div>
                        <div class="entry-excerpt">
                            @(entry.Content.Length > 160
                                                    ? entry.Content.Substring(0, 160) + "…"
                                                    : entry.Content)
                    </div>
                </div>
            </a>
                        }
            </div>
        }

    </div>
</div>
