@model deneme2._0.Models.Folder

@{
    ViewData["Title"] = Model.Name + " Klasörü";
    var entries = Model.JournalEntryFolders
        .Where(jef => jef.JournalEntry != null)
        .Select(jef => jef.JournalEntry!)
        .OrderByDescending(e => e.CreatedAt)
        .ToList();
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@@0,400;0,600;1,400&family=DM+Sans:wght@@300;400;500&display=swap');

    body {
        background: #FAF7F2;
        font-family: 'DM Sans', sans-serif;
        color: #2C2416;
    }

    .entries-page {
        max-width: 760px;
        margin: 0 auto;
        padding: 32px 16px 64px;
    }

    .breadcrumb {
        font-size: 12px;
        color: #A89880;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 8px;
    }

        .breadcrumb a {
            color: #A89880;
            text-decoration: none;
        }

            .breadcrumb a:hover {
                color: #8B4513;
            }

    .page-title {
        font-family: 'Lora', serif;
        font-size: 26px;
        font-weight: 400;
        font-style: italic;
        color: #2C2416;
        margin: 0 0 28px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .count-chip {
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-style: normal;
        font-weight: 500;
        color: #8B4513;
        background: rgba(139,69,19,0.09);
        border-radius: 20px;
        padding: 3px 11px;
    }

    .entry-card {
        background: #FFFDF8;
        border: 1px solid #E8DFD0;
        border-radius: 16px;
        padding: 18px;
        display: flex;
        gap: 16px;
        margin-bottom: 14px;
        text-decoration: none;
        color: #2C2416;
        box-shadow: 0 2px 10px rgba(44,36,22,0.05);
        transition: all 0.2s ease;
    }

        .entry-card:hover {
            box-shadow: 0 6px 22px rgba(44,36,22,0.10);
            transform: translateY(-2px);
            border-color: #D4956A;
            text-decoration: none;
            color: #2C2416;
        }

    .entry-thumb {
        width: 72px;
        height: 72px;
        border-radius: 10px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .entry-thumb-placeholder {
        width: 72px;
        height: 72px;
        border-radius: 10px;
        background: #F0EAE0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .entry-body {
        flex: 1;
        min-width: 0;
    }

    .entry-date {
        font-size: 11.5px;
        color: #A89880;
        margin-bottom: 4px;
    }

    .entry-title {
        font-family: 'Lora', serif;
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .entry-excerpt {
        font-size: 13px;
        color: #6B5744;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .empty-state {
        text-align: center;
        padding: 48px 16px;
        color: #A89880;
    }

        .empty-state p {
            font-size: 14px;
            margin: 8px 0 20px;
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 10px;
        background: transparent;
        color: #6B5744;
        border: 1.5px solid #D4C5B0;
        font-size: 13px;
        text-decoration: none;
        transition: background 0.15s;
        margin-bottom: 24px;
    }

        .btn-back:hover {
            background: rgba(139,69,19,0.06);
            color: #2C2416;
            text-decoration: none;
        }
</style>

<div class="entries-page">

    <a asp-controller="Folder" asp-action="Index" class="btn-back">← Klasörler</a>

    <div class="breadcrumb">
        <a asp-controller="Folder" asp-action="Index">Klasörler</a>
        <span>›</span>
        <span>@Model.Name</span>
    </div>

    <h1 class="page-title">
        @Model.Emoji @Model.Name
        <span class="count-chip">@entries.Count günlük</span>
    </h1>

    @if (!entries.Any())
    {
        <div class="empty-state">
            <div style="font-size:44px;">📂</div>
            <p>Bu klasörde henüz günlük yok.</p>
            <a asp-controller="Journal" asp-action="Index" class="btn-back">Günlüklere Git</a>
        </div>
    }
    else
    {
        foreach (var entry in entries)
        {
            <a asp-controller="Journal" asp-action="Details" asp-route-id="@entry.Id"
               class="entry-card">
                @if (entry.Images != null && entry.Images.Any())
                {
                    <img src="data:@entry.Images.First().ImageContentType;base64,@Convert.ToBase64String(entry.Images.First().ImageData)"
                         class="entry-thumb" alt="" />
                }
                else
                {
                    <div class="entry-thumb-placeholder">✍️</div>
                }
                <div class="entry-body">
                    <div class="entry-date">@entry.CreatedAt.ToString("dd MMMM yyyy")</div>
                    <div class="entry-title">@entry.Title</div>
                    <div class="entry-excerpt">
                        @(entry.Content.Length > 160 ? entry.Content.Substring(0, 160) + "…" : entry.Content)
                    </div>
                </div>
            </a>
        }
    }

</div>