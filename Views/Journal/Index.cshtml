@model List<deneme2._0.Models.JournalEntry>

@{
    ViewData["Title"] = "Günlüklerim";
    var selectedDate = ViewBag.SelectedDate as DateTime? ?? DateTime.Today;
    var currentYear = ViewBag.Year ?? DateTime.Today.Year;
    var currentMonth = ViewBag.Month ?? DateTime.Today.Month;
    var entriesByDate = ViewBag.EntriesByDate as Dictionary<DateTime, List<JournalEntry>> ?? new Dictionary<DateTime, List<JournalEntry>>();
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@@0,400;0,600;1,400&family=DM+Sans:wght@@300;400;500&display=swap');

    :root {
        --ink: #2C2416;
        --ink-soft: #6B5E4A;
        --ink-faint: #A89880;
        --paper: #FAF7F2;
        --paper-warm: #F3EDE3;
        --paper-crease: #E8DFD0;
        --accent: #8B4513;
        --accent-light: #D4956A;
        --accent-glow: rgba(139, 69, 19, 0.12);
        --today: #5C7A4E;
        --today-light: rgba(92, 122, 78, 0.12);
        --radius: 12px;
        --shadow-soft: 0 2px 16px rgba(44, 36, 22, 0.08);
        --shadow-lift: 0 6px 28px rgba(44, 36, 22, 0.14);
    }

    * {
        box-sizing: border-box;
    }

    body {
        background: var(--paper);
        font-family: 'DM Sans', sans-serif;
        color: var(--ink);
    }

    .journal-layout {
        display: flex;
        gap: 28px;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 4px;
        align-items: flex-start;
    }

    /* ── CALENDAR SIDEBAR ── */
    .cal-sidebar {
        width: 300px;
        flex-shrink: 0;
        position: sticky;
        top: 24px;
        margin-top: 30px;
        background: #FFFDF8;
        border-radius: 18px;
        padding: 20px 18px 22px;
        border: 1px solid var(--paper-crease);
        box-shadow: var(--shadow-soft);
    }

    .cal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

    .cal-title {
        font-family: 'Lora', serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--ink);
        letter-spacing: 0.3px;
    }

    .cal-nav {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid var(--paper-crease);
        background: var(--paper);
        color: var(--ink-soft);
        text-decoration: none;
        font-size: 16px;
        line-height: 1;
        transition: all 0.18s ease;
    }

        .cal-nav:hover {
            background: var(--accent-glow);
            border-color: var(--accent-light);
            color: var(--accent);
        }

    .cal-weekdays {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        text-align: center;
        margin-bottom: 8px;
    }

        .cal-weekdays span {
            font-size: 11px;
            font-weight: 500;
            color: var(--ink-faint);
            letter-spacing: 0.5px;
            text-transform: uppercase;
            padding: 4px 0;
        }

    .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 3px;
    }

    .cal-day {
        position: relative;
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 13px;
        color: var(--ink-soft);
        text-decoration: none;
        transition: all 0.15s ease;
        font-family: 'DM Sans', sans-serif;
        font-weight: 400;
    }

        .cal-day:hover {
            background: var(--paper-warm);
            color: var(--ink);
        }

        .cal-day.has-entry {
            background: var(--accent-glow);
            color: var(--accent);
            font-weight: 500;
        }

            .cal-day.has-entry:hover {
                background: rgba(139, 69, 19, 0.2);
            }

        .cal-day.selected {
            background: var(--accent) !important;
            color: #FFF8F0 !important;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(139, 69, 19, 0.35);
        }

        .cal-day.is-today:not(.selected)::after {
            content: '';
            position: absolute;
            bottom: 4px;
            left: 50%;
            transform: translateX(-50%);
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--today);
        }

        .cal-day.future {
            color: var(--paper-crease);
            cursor: not-allowed;
            pointer-events: none;
        }

    .entry-dot {
        position: absolute;
        top: 3px;
        right: 3px;
        min-width: 14px;
        height: 14px;
        padding: 0 3px;
        background: var(--accent);
        color: #FFF8F0;
        border-radius: 7px;
        font-size: 8px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

    .cal-day.selected .entry-dot {
        background: rgba(255,248,240,0.9);
        color: var(--accent);
    }

    /* ── ENTRIES PANEL ── */
    .entries-panel {
        flex: 1;
        min-width: 0;
        margin-top: 30px;
    }

    .date-heading {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 22px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .date-day-num {
        font-family: 'Lora', serif;
        font-size: 52px;
        font-weight: 400;
        color: var(--ink);
        line-height: 1;
        margin-right: 12px;
    }

    .date-rest {
        display: flex;
        flex-direction: column;
    }

    .date-month-year {
        font-family: 'Lora', serif;
        font-size: 18px;
        font-weight: 600;
        color: var(--ink);
    }

    .date-weekday {
        font-size: 13px;
        color: var(--ink-faint);
        text-transform: lowercase;
        letter-spacing: 0.3px;
        margin-top: 1px;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 10px;
        background: var(--accent);
        color: #FFF8F0;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.18s ease;
        border: none;
        cursor: pointer;
    }

        .btn-add:hover {
            background: #7A3B10;
            box-shadow: 0 4px 14px rgba(139,69,19,0.3);
            transform: translateY(-1px);
            color: #FFF8F0;
        }

    .btn-add-ghost {
        background: transparent;
        color: var(--accent);
        border: 1.5px solid var(--accent-light);
    }

        .btn-add-ghost:hover {
            background: var(--accent-glow);
            box-shadow: none;
            color: var(--accent);
        }

    .divider-line {
        height: 1px;
        background: linear-gradient(to right, var(--paper-crease), transparent);
        margin-bottom: 22px;
    }

    /* Empty state */
    .empty-state {
        background: #FFFDF8;
        border: 1.5px dashed var(--paper-crease);
        border-radius: 16px;
        padding: 48px 32px;
        text-align: center;
    }

    .empty-icon {
        font-size: 40px;
        margin-bottom: 12px;
        opacity: 0.5;
        display: block;
    }

    .empty-state h4 {
        font-family: 'Lora', serif;
        font-size: 18px;
        font-weight: 600;
        color: var(--ink-soft);
        margin: 0 0 6px;
    }

    .empty-state p {
        font-size: 14px;
        color: var(--ink-faint);
        margin: 0 0 24px;
    }

    /* Entry cards */
    .entry-card {
        display: flex;
        gap: 16px;
        background: #FFFDF8;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 14px;
        border: 1px solid var(--paper-crease);
        box-shadow: var(--shadow-soft);
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
    }

        .entry-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: var(--accent-light);
            border-radius: 3px 0 0 3px;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .entry-card:hover {
            box-shadow: var(--shadow-lift);
            transform: translateY(-2px);
            border-color: var(--accent-light);
        }

            .entry-card:hover::before {
                opacity: 1;
            }

    .entry-thumb {
        width: 88px;
        height: 88px;
        object-fit: cover;
        border-radius: 10px;
        flex-shrink: 0;
        border: 1px solid var(--paper-crease);
    }

    .entry-thumb-placeholder {
        width: 88px;
        height: 88px;
        border-radius: 10px;
        background: var(--paper-warm);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        opacity: 0.6;
        border: 1px solid var(--paper-crease);
    }

    .entry-body {
        flex: 1;
        min-width: 0;
    }

    .entry-title {
        font-family: 'Lora', serif;
        font-size: 17px;
        font-weight: 600;
        color: var(--ink);
        margin: 0 0 7px;
        line-height: 1.3;
    }

    .entry-preview {
        font-size: 13.5px;
        color: var(--ink-soft);
        line-height: 1.6;
        margin: 0 0 14px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .entry-actions {
        display: flex;
        gap: 8px;
    }

    .btn-sm {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 13px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s ease;
        border: 1px solid transparent;
        font-family: 'DM Sans', sans-serif;
    }

    .btn-detail {
        background: var(--paper-warm);
        color: var(--ink-soft);
        border-color: var(--paper-crease);
    }

        .btn-detail:hover {
            background: var(--paper-crease);
            color: var(--ink);
        }

    .btn-edit {
        background: transparent;
        color: var(--accent);
        border-color: var(--accent-light);
    }

        .btn-edit:hover {
            background: var(--accent-glow);
            color: var(--accent);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .journal-layout {
            flex-direction: column;
        }

        .cal-sidebar {
            width: 100%;
            position: static;
        }

        .date-day-num {
            font-size: 40px;
        }
    }
</style>


<form asp-controller="Journal" asp-action="Search" method="get"
      style="max-width:1320px; margin:16px auto 0; padding:0 4px; display:flex; gap:8px;">
    <input type="text" name="q" placeholder="Günlüklerimde ara…"
           style="flex:1; padding:10px 16px; border-radius:10px; border:1.5px solid #E8DFD0;
    background:#FFFDF8; font-family:'DM Sans',sans-serif; font-size:14px;
    color:#2C2416; outline:none;" />
    <button type="submit"
            style="padding:10px 18px; border-radius:10px; background:#8B4513; color:#FFF8F0;
        border:none; font-size:14px; cursor:pointer;">
        🔍 Ara
    </button>
</form>


<div class="journal-layout">

    <!-- ── SOL: TAKVİM ── -->
    <aside class="cal-sidebar">
        <div class="cal-header">
            @{
                var nextYear = currentMonth == 12 ? currentYear + 1 : currentYear;
                var nextMonth = currentMonth == 12 ? 1 : currentMonth + 1;
                var isNextMonthFuture = new DateTime(nextYear, nextMonth, 1) > new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
            }

            <a asp-action="Index"
               asp-route-year="@(currentMonth == 1 ? currentYear - 1 : currentYear)"
               asp-route-month="@(currentMonth == 1 ? 12 : currentMonth - 1)"
               asp-route-day="1"
               class="cal-nav">‹</a>

            <span class="cal-title">@(new DateTime(currentYear, currentMonth, 1).ToString("MMMM yyyy"))</span>

            @if (!isNextMonthFuture)
            {
                <a asp-action="Index"
                   asp-route-year="@nextYear"
                   asp-route-month="@nextMonth"
                   asp-route-day="1"
                   class="cal-nav">›</a>
            }
            else
            {
                <span class="cal-nav" style="opacity:0.25; cursor:not-allowed;">›</span>
            }
        </div>

        <div class="cal-weekdays">
            <span>Pzt</span><span>Sal</span><span>Çar</span><span>Per</span>
            <span>Cum</span><span>Cmt</span><span>Paz</span>
        </div>

        <div class="cal-grid">
            @{
                var firstDay = new DateTime(currentYear, currentMonth, 1);
                var startDow = (int)firstDay.DayOfWeek;
                startDow = startDow == 0 ? 6 : startDow - 1;
                var daysInMonth = DateTime.DaysInMonth(currentYear, currentMonth);

                for (int i = 0; i < startDow; i++)
                {
                    <div class="cal-day"></div>
                }

                for (int day = 1; day <= daysInMonth; day++)
                {
                    var date = new DateTime(currentYear, currentMonth, day);
                    var isFuture = date.Date > DateTime.Today;
                    var isToday = date.Date == DateTime.Today;
                    var hasEntry = entriesByDate.ContainsKey(date);
                    var count = hasEntry ? entriesByDate[date].Count : 0;
                    var isSelected = date.Date == selectedDate.Date;

                    var classes = "cal-day";
                    if (isFuture) classes += " future";
                    if (hasEntry) classes += " has-entry";
                    if (isSelected) classes += " selected";
                    if (isToday) classes += " is-today";

                    if (isFuture)
                    {
                        <div class="@classes">@day</div>
                    }
                    else
                    {
                        <a asp-action="Index" asp-route-year="@currentYear"
                           asp-route-month="@currentMonth" asp-route-day="@day"
                           class="@classes">
                            @day
                            @if (hasEntry)
                            {
                                <span class="entry-dot">@count</span>
                            }
                        </a>
                    }
                }
            }
        </div>
    </aside>

    <!-- ── SAĞ: ENTRIES ── -->
    <main class="entries-panel">
        <div class="date-heading">
            <div style="display:flex; align-items:baseline; gap:4px;">
                <span class="date-day-num">@selectedDate.Day</span>
                <div class="date-rest">
                    <span class="date-month-year">@selectedDate.ToString("MMMM yyyy")</span>
                    <span class="date-weekday">@selectedDate.ToString("dddd")</span>
                </div>
            </div>
            @if (Model.Any())
            {
                <a asp-action="Create" asp-route-date="@selectedDate.ToString("yyyy-MM-dd")"
                   class="btn-add btn-add-ghost">
                    + bir günlük daha ekle
                </a>
            }
        </div>

        <div class="divider-line"></div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <span class="empty-icon">📖</span>
                <h4>Bugün şu anlık boş</h4>
                <p>Bugün aklından geçenleri, hissettiklerini kayıt altına al.</p>
                <a asp-action="Create" asp-route-date="@selectedDate.ToString("yyyy-MM-dd")"
                   class="btn-add">
                    + Yeni Günlük Ekle
                </a>
            </div>
        }
        else
        {
            foreach (var entry in Model)
            {
                <article class="entry-card" onclick="window.location='@Url.Action("Details", new { id = entry.Id })'">
                    @if (entry.Images != null && entry.Images.Any())
                    {
                        <img src="data:@entry.Images.First().ImageContentType;base64,@Convert.ToBase64String(entry.Images.First().ImageData)"
                             class="entry-thumb" alt="" />
                    }
                    else
                    {
                        <div class="entry-thumb-placeholder">✍️</div>
                    }
                    <div class="entry-body">
                        <h3 class="entry-title">@entry.Title</h3>
                        <p class="entry-preview">
                            @(entry.Content.Length > 130 ? entry.Content.Substring(0, 130) + "…" : entry.Content)
                        </p>
                        <div class="entry-actions">
                            <a asp-action="Edit" asp-route-id="@entry.Id" class="btn-sm btn-edit"
                               onclick="event.stopPropagation()">Düzenle</a>
                        </div>
                    </div>
                </article>
            }
        }
    </main>

</div>
