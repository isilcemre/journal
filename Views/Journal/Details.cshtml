@model deneme2._0.Models.JournalEntry

@{
    ViewData["Title"] = Model.Title;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@@0,400;0,600;1,400&family=DM+Sans:wght@@300;400;500&display=swap');

    :root {
        --ink: #2C2416;
        --ink-soft: #6B5E4A;
        --ink-faint: #A89880;
        --paper: #FAF7F2;
        --paper-warm: #F3EDE3;
        --paper-crease: #E8DFD0;
        --accent: #8B4513;
        --accent-light: #D4956A;
        --accent-glow: rgba(139, 69, 19, 0.12);
        --radius: 12px;
        --shadow-soft: 0 2px 16px rgba(44, 36, 22, 0.08);
        --shadow-lift: 0 6px 28px rgba(44, 36, 22, 0.14);
    }

    * {
        box-sizing: border-box;
    }

    body {
        background: var(--paper);
        font-family: 'DM Sans', sans-serif;
        color: var(--ink);
    }

    .detail-layout {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 4px;
    }

    /* ── HEADER ── */
    .detail-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 24px;
    }

    .detail-title {
        font-family: 'Lora', serif;
        font-size: 32px;
        font-weight: 600;
        color: var(--ink);
        line-height: 1.25;
        margin: 0;
    }

    .detail-meta {
        font-size: 13px;
        color: var(--ink-faint);
        white-space: nowrap;
    }

    .divider-line {
        height: 1px;
        background: linear-gradient(to right, var(--paper-crease), transparent);
        margin-bottom: 24px;
    }

    /* ── CARD ── */
    .detail-card {
        background: #FFFDF8;
        border-radius: 18px;
        border: 1px solid var(--paper-crease);
        box-shadow: var(--shadow-soft);
        overflow: hidden;
    }

    .detail-card-body {
        padding: 28px 28px 20px;
    }

    .detail-card-footer {
        display: flex;
        gap: 10px;
        padding: 16px 28px;
        border-top: 1px solid var(--paper-crease);
        background: var(--paper-warm);
    }

    /* ── GALLERY ── */
    .gallery-container {
        position: relative;
        display: flex;
        align-items: center;
        margin-bottom: 28px;
        width: 100%;
    }

    .gallery-wrapper {
        overflow: hidden;
        width: 100%;
        border-radius: 14px;
    }

    .gallery-track {
        display: flex;
        gap: 14px;
        transition: transform 0.4s ease;
        padding: 6px;
    }

    .gallery-item {
        flex: 0 0 auto;
    }

    .gallery-image {
        width: 200px;
        height: 200px;
        object-fit: cover;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-soft);
        border: 1px solid var(--paper-crease);
    }

        .gallery-image:hover {
            transform: scale(1.06);
            box-shadow: var(--shadow-lift);
            border-color: var(--accent-light);
        }

    .nav-btn {
        position: absolute;
        z-index: 5;
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: rgba(44, 36, 22, 0.55);
        color: #FFF8F0;
        font-size: 18px;
        cursor: pointer;
        transition: 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .nav-btn:hover {
            background: rgba(44, 36, 22, 0.85);
            transform: scale(1.1);
        }

        .nav-btn.left {
            left: 8px;
        }

        .nav-btn.right {
            right: 8px;
        }

    .no-photo-state {
        background: var(--paper-warm);
        border: 1.5px dashed var(--paper-crease);
        border-radius: 14px;
        padding: 28px;
        text-align: center;
        color: var(--ink-faint);
        font-size: 14px;
        margin-bottom: 28px;
    }

    /* ── CONTENT ── */
    .entry-content {
        font-family: 'Lora', serif;
        font-size: 16px;
        line-height: 1.85;
        color: var(--ink-soft);
    }

    .content-divider {
        height: 1px;
        background: linear-gradient(to right, var(--paper-crease), transparent);
        margin: 22px 0;
    }

    /* ── TIMESTAMPS ── */
    .timestamps {
        font-size: 12.5px;
        color: var(--ink-faint);
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    /* ── BUTTONS ── */
    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 9px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.18s ease;
        border: 1.5px solid transparent;
        cursor: pointer;
    }

    .btn-edit {
        background: transparent;
        color: var(--accent);
        border-color: var(--accent-light);
    }

        .btn-edit:hover {
            background: var(--accent-glow);
            color: var(--accent);
            transform: translateY(-1px);
        }

    .btn-back {
        background: var(--paper-warm);
        color: var(--ink-soft);
        border-color: var(--paper-crease);
    }

        .btn-back:hover {
            background: var(--paper-crease);
            color: var(--ink);
        }

    /* ── LIGHTBOX ── */
    .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.92);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 99999;
        animation: fadeIn 0.25s ease;
    }

        .lightbox img {
            max-width: 90%;
            max-height: 90%;
            border-radius: 12px;
            box-shadow: 0 0 40px rgba(0,0,0,0.6);
        }

    .lightbox-close,
    .lightbox-prev,
    .lightbox-next {
        position: absolute;
        color: rgba(255,255,255,0.85);
        font-size: 32px;
        cursor: pointer;
        user-select: none;
        transition: 0.2s;
        background: rgba(255,255,255,0.08);
        width: 46px;
        height: 46px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

        .lightbox-close:hover,
        .lightbox-prev:hover,
        .lightbox-next:hover {
            background: rgba(255,255,255,0.18);
            color: #fff;
        }

    .lightbox-close {
        top: 20px;
        right: 24px;
        font-size: 22px;
    }

    .lightbox-prev {
        left: 24px;
        top: 50%;
        transform: translateY(-50%);
    }

    .lightbox-next {
        right: 24px;
        top: 50%;
        transform: translateY(-50%);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    /* ── KLASÖR PANELİ ── */
    .folder-panel {
        background: #FFFDF8;
        border: 1px solid var(--paper-crease);
        border-radius: 18px;
        padding: 20px 24px;
        margin-top: 20px;
        box-shadow: var(--shadow-soft);
    }

    .folder-panel-title {
        font-family: 'Lora', serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--ink);
        margin: 0 0 14px;
    }

    .folder-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .folder-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        border: 1.5px solid var(--paper-crease);
        background: var(--paper-warm);
        color: var(--ink-soft);
        cursor: pointer;
        transition: all 0.18s;
        text-decoration: none;
        background: none;
        font-family: 'DM Sans', sans-serif;
    }

        .folder-tag:hover {
            border-color: var(--accent-light);
            background: var(--accent-glow);
            color: var(--accent);
        }

        .folder-tag.active {
            background: var(--accent-glow);
            border-color: var(--accent);
            color: var(--accent);
        }

            .folder-tag.active .tag-remove {
                display: inline;
            }

        .folder-tag .tag-remove {
            display: none;
            font-size: 11px;
            opacity: 0.7;
        }

    @@media (max-width: 768px) {
        .detail-title {
            font-size: 24px;
        }

        .detail-card-body {
            padding: 18px 16px 14px;
        }

        .detail-card-footer {
            padding: 14px 16px;
        }

        .gallery-image {
            width: 150px;
            height: 150px;
        }

        .nav-btn {
            width: 34px;
            height: 34px;
            font-size: 16px;
        }
    }
</style>

<div class="detail-layout">

    <!-- HEADER -->
    <div class="detail-header">
        <h2 class="detail-title">@Model.Title</h2>
        <span class="detail-meta">
            @Model.CreatedAt.ToString("dd MMMM yyyy")
        </span>
    </div>

    <div class="divider-line"></div>

    <!-- CARD -->
    <div class="detail-card">
        <div class="detail-card-body">

            <!-- GALERİ -->
            @if (Model.Images != null && Model.Images.Any())
            {
                <div class="gallery-container">
                    <button class="nav-btn left" id="prevBtn">❮</button>
                    <div class="gallery-wrapper" id="galleryWrapper">
                        <div class="gallery-track">
                            @foreach (var image in Model.Images)
                            {
                                <div class="gallery-item">
                                    <img src="data:@image.ImageContentType;base64,@Convert.ToBase64String(image.ImageData)"
                                         alt="Fotoğraf"
                                         class="gallery-image"
                                         data-full="data:@image.ImageContentType;base64,@Convert.ToBase64String(image.ImageData)" />
                                </div>
                            }
                        </div>
                    </div>
                    <button class="nav-btn right" id="nextBtn">❯</button>
                </div>
            }
            else
            {
                <div class="no-photo-state">
                    📷 Bu günlükte henüz fotoğraf yok.
                </div>
            }

            <!-- İÇERİK -->
            <div class="entry-content">
                @Html.Raw(Model.Content)
            </div>

            <div class="content-divider"></div>

            <!-- ZAMAN DAMGALARI -->
            <div class="timestamps">
                <span>✍️ Oluşturuldu: @Model.CreatedAt.ToString("dd.MM.yyyy")</span>
                @if (Model.UpdatedAt.HasValue)
                {
                    <span>🔄 Güncellendi: @Model.UpdatedAt.Value.ToString("dd.MM.yyyy")</span>
                }
            </div>

        </div>

        <!-- FOOTER -->
        <div class="detail-card-footer">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-action btn-edit">
                ✏️ Düzenle
            </a>
            <a asp-action="Index"
               asp-route-year="@Model.CreatedAt.Year"
               asp-route-month="@Model.CreatedAt.Month"
               asp-route-day="@Model.CreatedAt.Day"
               class="btn-action btn-back">
                ← Listeye Dön
            </a>
        </div>
    </div>

</div>

@{
    var allFolders = ViewBag.AllFolders as List<deneme2._0.Models.Folder> ?? new();
    var entryFolderIds = ViewBag.EntryFolderIds as List<int> ?? new();
}

<!-- KLASÖR PANELİ -->
<div class="folder-panel">
    <p class="folder-panel-title">📁 Klasörler</p>
    <div class="folder-tags">
        @foreach (var folder in allFolders)
        {
            var isInFolder = entryFolderIds.Contains(folder.Id);

            if (isInFolder)
            {
                <!-- Klasörde var → tıklayınca çıkar -->
                <form asp-controller="Folder" asp-action="RemoveEntry" method="post" style="display:inline;">
                    <input type="hidden" name="journalEntryId" value="@Model.Id" />
                    <input type="hidden" name="folderId" value="@folder.Id" />
                    <button type="submit" class="folder-tag active">
                        @folder.Emoji @folder.Name
                        <span class="tag-remove">✕</span>
                    </button>
                </form>
            }
            else
            {
                <!-- Klasörde yok → tıklayınca ekle -->
                <form asp-controller="Folder" asp-action="AddEntry" method="post" style="display:inline;">
                    <input type="hidden" name="journalEntryId" value="@Model.Id" />
                    <input type="hidden" name="folderId" value="@folder.Id" />
                    <button type="submit" class="folder-tag">
                        @folder.Emoji @folder.Name
                    </button>
                </form>
            }
        }
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const wrapper = document.getElementById("galleryWrapper");

        if (wrapper) {
            document.getElementById("prevBtn").addEventListener("click", () => {
                wrapper.scrollBy({ left: -280, behavior: "smooth" });
            });

            document.getElementById("nextBtn").addEventListener("click", () => {
                wrapper.scrollBy({ left: 280, behavior: "smooth" });
            });
        }

        // LIGHTBOX
        const images = document.querySelectorAll(".gallery-image");
        let currentIndex = 0;

        images.forEach((img, index) => {
            img.addEventListener("click", () => {
                currentIndex = index;
                openLightbox(img.dataset.full);
            });
        });

        function openLightbox(src) {
            const lightbox = document.createElement("div");
            lightbox.classList.add("lightbox");
            lightbox.innerHTML = `
                <span class="lightbox-close">✕</span>
                <span class="lightbox-prev">❮</span>
                <img src="${src}">
                <span class="lightbox-next">❯</span>
            `;
            document.body.appendChild(lightbox);

            const imgEl = lightbox.querySelector("img");

            function updateImage() {
                imgEl.src = images[currentIndex].dataset.full;
            }

            lightbox.querySelector(".lightbox-close").addEventListener("click", () => {
                lightbox.remove();
            });

            lightbox.querySelector(".lightbox-prev").addEventListener("click", (e) => {
                e.stopPropagation();
                currentIndex = (currentIndex - 1 + images.length) % images.length;
                updateImage();
            });

            lightbox.querySelector(".lightbox-next").addEventListener("click", (e) => {
                e.stopPropagation();
                currentIndex = (currentIndex + 1) % images.length;
                updateImage();
            });

            lightbox.addEventListener("click", (e) => {
                if (e.target === lightbox) lightbox.remove();
            });
        }

    });
</script>
