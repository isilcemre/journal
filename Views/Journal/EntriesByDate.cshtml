@model List<deneme2._0.Models.JournalEntry>

@{
    ViewData["Title"] = ViewBag.SelectedDate + " - Günlükler";
}

<h2>📓 @ViewBag.SelectedDate tarihli günlükler</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">Bu tarihte hiç günlük entry'si yok.</div>
    <a asp-action="Create" class="btn btn-success">+ Yeni Günlük Ekle</a>
}
else
{
    <div class="row">
        @foreach (var entry in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    @if (entry.Images != null && entry.Images.Any())
                    {
                        <img src="data:@entry.Images.First().ImageContentType;base64,@Convert.ToBase64String(entry.Images.First().ImageData)"
                             class="card-img-top" style="height: 200px; object-fit: cover;" />
                    }
                    <div class="card-body">
                        <h5>@entry.Title</h5>
                        <p>@(entry.Content.Length > 150 ? entry.Content.Substring(0, 150) + "..." : entry.Content)</p>
                        <a asp-action="Details" asp-route-id="@entry.Id" class="btn btn-primary">Detay</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<a asp-action="Calendar" class="btn btn-secondary">← Takvime Dön</a>