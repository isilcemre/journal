@model List<deneme2._0.Models.JournalEntry>

@{
    ViewData["Title"] = "Arama Sonuçları";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@@0,400;0,600;1,400&family=DM+Sans:wght@@300;400;500&display=swap');

    :root {
        --ink: #2C2416;
        --ink-soft: #6B5E4A;
        --ink-faint: #A89880;
        --paper: #FAF7F2;
        --paper-warm: #F3EDE3;
        --paper-crease: #E8DFD0;
        --accent: #8B4513;
        --accent-light: #D4956A;
        --accent-glow: rgba(139, 69, 19, 0.12);
        --radius: 12px;
        --shadow-soft: 0 2px 16px rgba(44, 36, 22, 0.08);
        --shadow-lift: 0 6px 28px rgba(44, 36, 22, 0.14);
    }

    body {
        background: var(--paper);
        font-family: 'DM Sans', sans-serif;
        color: var(--ink);
    }

    .search-page {
        max-width: 820px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    /* Arama kutusu */
    .search-box-wrap {
        display: flex;
        gap: 10px;
        margin-bottom: 32px;
    }

    .search-input {
        flex: 1;
        padding: 12px 18px;
        border-radius: 12px;
        border: 1.5px solid var(--paper-crease);
        background: #FFFDF8;
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        color: var(--ink);
        outline: none;
        transition: border-color 0.2s;
    }

        .search-input:focus {
            border-color: var(--accent-light);
        }

    .search-btn {
        padding: 12px 22px;
        border-radius: 12px;
        background: var(--accent);
        color: #FFF8F0;
        border: none;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.18s ease;
    }

        .search-btn:hover {
            background: #7A3B10;
        }

    /* Sonuç başlığı */
    .result-header {
        margin-bottom: 20px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--paper-crease);
    }

        .result-header h2 {
            font-family: 'Lora', serif;
            font-size: 22px;
            font-weight: 600;
            color: var(--ink);
            margin: 0 0 4px;
        }

        .result-header p {
            font-size: 13px;
            color: var(--ink-faint);
            margin: 0;
        }

    .highlight {
        background: rgba(139, 69, 19, 0.15);
        color: var(--accent);
        border-radius: 3px;
        padding: 0 2px;
        font-weight: 600;
    }

    /* Kartlar — Index'teki ile aynı stil */
    .entry-card {
        display: flex;
        gap: 16px;
        background: #FFFDF8;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 14px;
        border: 1px solid var(--paper-crease);
        box-shadow: var(--shadow-soft);
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

        .entry-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: var(--accent-light);
            border-radius: 3px 0 0 3px;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .entry-card:hover {
            box-shadow: var(--shadow-lift);
            transform: translateY(-2px);
            border-color: var(--accent-light);
        }

            .entry-card:hover::before {
                opacity: 1;
            }

    .entry-thumb {
        width: 88px;
        height: 88px;
        object-fit: cover;
        border-radius: 10px;
        flex-shrink: 0;
        border: 1px solid var(--paper-crease);
    }

    .entry-thumb-placeholder {
        width: 88px;
        height: 88px;
        border-radius: 10px;
        background: var(--paper-warm);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        opacity: 0.6;
        border: 1px solid var(--paper-crease);
    }

    .entry-body {
        flex: 1;
        min-width: 0;
    }

    .entry-title {
        font-family: 'Lora', serif;
        font-size: 17px;
        font-weight: 600;
        color: var(--ink);
        margin: 0 0 4px;
    }

    .entry-date {
        font-size: 12px;
        color: var(--ink-faint);
        margin: 0 0 8px;
    }

    .entry-preview {
        font-size: 13.5px;
        color: var(--ink-soft);
        line-height: 1.6;
        margin: 0 0 14px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .entry-actions {
        display: flex;
        gap: 8px;
    }

    .btn-sm {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 13px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s ease;
        border: 1px solid transparent;
        font-family: 'DM Sans', sans-serif;
    }

    .btn-detail {
        background: var(--paper-warm);
        color: var(--ink-soft);
        border-color: var(--paper-crease);
    }

        .btn-detail:hover {
            background: var(--paper-crease);
            color: var(--ink);
        }

    .btn-edit {
        background: transparent;
        color: var(--accent);
        border-color: var(--accent-light);
    }

        .btn-edit:hover {
            background: var(--accent-glow);
            color: var(--accent);
        }

    .empty-state {
        background: #FFFDF8;
        border: 1.5px dashed var(--paper-crease);
        border-radius: 16px;
        padding: 48px 32px;
        text-align: center;
    }

        .empty-state h4 {
            font-family: 'Lora', serif;
            font-size: 18px;
            color: var(--ink-soft);
            margin: 0 0 8px;
        }

        .empty-state p {
            font-size: 14px;
            color: var(--ink-faint);
            margin: 0;
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--ink-faint);
        font-size: 13px;
        text-decoration: none;
        margin-bottom: 24px;
        transition: color 0.15s;
    }

        .back-link:hover {
            color: var(--accent);
        }
</style>

<div class="search-page">

    <a asp-action="Index" class="back-link">← Günlüğüme Dön</a>

    
    <form asp-action="Search" method="get" class="search-box-wrap">
        <input type="text"
               name="q"
               value="@searchTerm"
               placeholder="Günlüklerinizde ara…"
               class="search-input"
               autofocus />
        <button type="submit" class="search-btn">🔍 Ara</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(searchTerm))
    {
        <div class="result-header">
            <h2>"@searchTerm" için sonuçlar</h2>
            <p>@Model.Count günlük bulundu</p>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <h4>Sonuç bulunamadı</h4>
                <p>"@searchTerm" kelimesi hiçbir günlüğünüzde geçmiyor.</p>
            </div>
        }
        else
        {
            foreach (var entry in Model)
            {
                <article class="entry-card"
                         onclick="window.location='@Url.Action("Details", new { id = entry.Id })'">
                    @if (entry.Images != null && entry.Images.Any())
                    {
                        <img src="data:@entry.Images.First().ImageContentType;base64,@Convert.ToBase64String(entry.Images.First().ImageData)"
                             class="entry-thumb" alt="" />
                    }
                    else
                    {
                        <div class="entry-thumb-placeholder">✍️</div>
                    }

                    <div class="entry-body">
                        <h3 class="entry-title">@entry.Title</h3>
                        <p class="entry-date">@entry.CreatedAt.ToString("dd MMMM yyyy")</p>
                        <p class="entry-preview">
                            @(entry.Content.Length > 160 ? entry.Content.Substring(0, 160) + "…" : entry.Content)
                        </p>
                        <div class="entry-actions">
                            <a asp-action="Details" asp-route-id="@entry.Id"
                               class="btn-sm btn-detail" onclick="event.stopPropagation()">Görüntüle</a>
                            <a asp-action="Edit" asp-route-id="@entry.Id"
                               class="btn-sm btn-edit" onclick="event.stopPropagation()">Düzenle</a>
                        </div>
                    </div>
                </article>
            }
        }
    }
</div>