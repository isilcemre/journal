@model deneme2._0.Models.CalendarViewModel

@{
    ViewData["Title"] = "Takvim Görünümü";
}

<h2>📅 @Model.MonthName @Model.Year</h2>

<div class="mb-3">
    <a asp-action="Calendar" asp-route-year="@(Model.Year)" asp-route-month="@(Model.Month - 1)" class="btn btn-primary">◀ Önceki Ay</a>
    <a asp-action="Calendar" asp-route-year="@(DateTime.Today.Year)" asp-route-month="@(DateTime.Today.Month)" class="btn btn-secondary">Bugün</a>
    <a asp-action="Calendar" asp-route-year="@(Model.Year)" asp-route-month="@(Model.Month + 1)" class="btn btn-primary">Sonraki Ay ▶</a>
</div>

<table class="table table-bordered text-center">
    <thead>
        <tr class="bg-dark text-white">
            <th>Pazartesi</th>
            <th>Salı</th>
            <th>Çarşamba</th>
            <th>Perşembe</th>
            <th>Cuma</th>
            <th>Cumartesi</th>
            <th>Pazar</th>
        </tr>
    </thead>
    <tbody>
        @{
            
            int firstDayOfWeek = (int)Model.FirstDayOfMonth;
            
            int offset = firstDayOfWeek == 0 ? 6 : firstDayOfWeek - 1;

            int dayCounter = 1;
            int totalDays = Model.DaysInMonth;
        }

        @for (int row = 0; row < 6; row++)
        {
            <tr>
                @for (int col = 0; col < 7; col++)
                {
                    int dayNumber = (row * 7) + col - offset + 1;

                    if (row == 0 && col < offset)
                    {
                        <td class="text-muted bg-light"></td>
                    }
                    else if (dayNumber > totalDays)
                    {
                        <td class="text-muted bg-light"></td>
                    }
                    var currentDate = new DateTime(Model.Year, Model.Month, dayNumber);
                    var isFuture = currentDate.Date > DateTime.Today;
                    var hasEntry = Model.EntriesByDate.ContainsKey(currentDate);
                    var entryCount = hasEntry ? Model.EntriesByDate[currentDate].Count : 0;

                    @if (isFuture)
                    {
                        <td class="text-muted bg-light" style="cursor: not-allowed; opacity: 0.5;">
                            <strong>@dayNumber</strong>
                        </td>
                    }
                    else
                    {
                        <td class="@(hasEntry ? "bg-info text-white" : "")" style="cursor: pointer;"
                            onclick="location.href='@Url.Action("EntriesByDate", new { date = currentDate.ToString("yyyy-MM-dd") })'">
                            <strong>@dayNumber</strong>
                            @if (hasEntry)
                            {
                                <br />
                                <span class="badge bg-warning text-dark">@entryCount</span>
                            }
                        </td>
                    }
                }
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Liste Görünümüne Dön</a>
    <a asp-action="Create" class="btn btn-success">Yeni Günlük Ekle</a>
</div>