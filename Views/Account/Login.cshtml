@model deneme2._0.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@@0,400;0,600;1,400&family=DM+Sans:wght@@300;400;500&display=swap');

    .login-page {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #FAF7F2;
        padding: 2.5rem;
        font-family: 'DM Sans', sans-serif;
    }

    .login-card {
        background: #FFFDF8;
        border: 1px solid #E8DFD0;
        border-radius: 18px;
        width: 100%;
        max-width: 400px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(44, 36, 22, 0.08);
    }

    .login-card-top {
        padding: 2rem 2rem 1.5rem;
        border-bottom: 1px solid #E8DFD0;
    }

    .login-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    .login-brand-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: rgba(139, 69, 19, 0.10);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .login-brand-name {
        font-family: 'Lora', serif;
        font-size: 16px;
        font-weight: 600;
        color: #2C2416;
    }

    .login-card-top h1 {
        font-family: 'Lora', serif;
        font-size: 22px;
        font-weight: 400;
        font-style: italic;
        color: #2C2416;
        margin: 0 0 5px;
        line-height: 1.3;
    }

    .login-card-top p {
        font-size: 13px;
        color: #A89880;
        margin: 0;
    }

    .login-card-body {
        padding: 1.5rem 2rem 2rem;
    }

    .login-alert-success {
        background: rgba(92, 122, 78, 0.10);
        border: 1px solid rgba(92, 122, 78, 0.25);
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #3B6D11;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .login-field {
        margin-bottom: 1rem;
    }

        .login-field label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            color: #6B5E4A;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .login-field .form-control {
            height: 40px;
            padding: 0 13px;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            background: #F3EDE3;
            border: 1px solid #E8DFD0;
            border-radius: 9px;
            color: #2C2416;
            transition: border-color .15s, box-shadow .15s, background .15s;
        }

            .login-field .form-control:focus {
                background: #FFFDF8;
                border-color: #D4956A;
                box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.10);
                outline: none;
            }

    .login-remember {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1.4rem;
    }

        .login-remember input[type=checkbox] {
            width: 15px;
            height: 15px;
            accent-color: #8B4513;
            cursor: pointer;
            margin: 0;
        }

        .login-remember label {
            font-size: 13px;
            color: #6B5E4A;
            cursor: pointer;
            margin: 0;
        }

    .btn-login {
        width: 100%;
        height: 42px;
        background: #8B4513;
        color: #FFF8F0;
        border: none;
        border-radius: 10px;
        font-family: 'Lora', serif;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background .18s, transform .15s, box-shadow .18s;
        letter-spacing: 0.2px;
    }

        .btn-login:hover {
            background: #7A3B10;
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(139, 69, 19, 0.28);
        }

    .login-divider {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 1.25rem 0;
    }

        .login-divider hr {
            flex: 1;
            border: none;
            border-top: 1px solid #E8DFD0;
            margin: 0;
        }

        .login-divider span {
            font-size: 12px;
            color: #A89880;
        }

    .btn-register-link {
        display: block;
        width: 100%;
        height: 40px;
        line-height: 38px;
        text-align: center;
        background: transparent;
        color: #8B4513;
        border: 1.5px solid #D4956A;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: background .15s;
    }

        .btn-register-link:hover {
            background: rgba(139, 69, 19, 0.07);
            color: #8B4513;
            text-decoration: none;
        }

    .login-quote {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid #E8DFD0;
    }

        .login-quote p {
            font-family: 'Lora', serif;
            font-size: 12px;
            font-style: italic;
            color: #A89880;
            line-height: 1.6;
            margin: 0;
        }
</style>

<div class="login-page">
    <div class="login-card">
        <div class="login-card-top">
            <div class="login-brand">
                <div class="login-brand-icon">📖</div>
                <span class="login-brand-name">Günlüğüm</span>
            </div>
            <h1>Tekrar hoş geldin</h1>
            <p>Bugünkü sayfana geçmek için giriş yap</p>
        </div>

        <div class="login-card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="login-alert-success">
                    ✓ @TempData["SuccessMessage"]
                </div>
            }

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:13px;"></div>

                <div class="login-field">
                    <label asp-for="Username"></label>
                    <input asp-for="Username" class="form-control" placeholder="kullanici_adi" />
                    <span asp-validation-for="Username" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="login-field">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="login-remember">
                    <input asp-for="RememberMe" />
                    <label asp-for="RememberMe"></label>
                </div>

                <button type="submit" class="btn-login">Giriş Yap</button>
            </form>

            <div class="login-divider"><hr /><span>veya</span><hr /></div>

            <a asp-action="Register" class="btn-register-link">
                Henüz hesabın yok mu? Oluştur
            </a>

            <div class="login-quote">
                <p>"Bir günlük tutmak, kendinle dürüst olmaktır."</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}